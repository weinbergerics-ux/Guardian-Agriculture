package com.guardian.model;

import jakarta.persistence.*;

@Entity
@Table(name = "environmental_impacts")
public class EnvironmentalImpact {
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;
    
    @OneToOne
    @JoinColumn(name = "product_id")
    private Product product;
    
    private Double waterSavedPercent;
    private Double co2ReducedPercent;
    private Double landSavedPercent;
    private Long waterSavedLiters;
    private Long co2SavedKg;
    private Long landSavedSqM;
    
    public EnvironmentalImpact() {}
    
    public EnvironmentalImpact(Product product, Double waterSavedPercent, 
                              Double co2ReducedPercent, Double landSavedPercent) {
        this.product = product;
        this.waterSavedPercent = waterSavedPercent;
        this.co2ReducedPercent = co2ReducedPercent;
        this.landSavedPercent = landSavedPercent;
    }
    
    // Getters and Setters
    public Long getId() { return id; }
    public void setId(Long id) { this.id = id; }
    
    public Product getProduct() { return product; }
    public void setProduct(Product product) { this.product = product; }
    
    public Double getWaterSavedPercent() { return waterSavedPercent; }
    public void setWaterSavedPercent(Double waterSavedPercent) { 
        this.waterSavedPercent = waterSavedPercent; 
    }
    
    public Double getCo2ReducedPercent() { return co2ReducedPercent; }
    public void setCo2ReducedPercent(Double co2ReducedPercent) { 
        this.co2ReducedPercent = co2ReducedPercent; 
    }
    
    public Double getLandSavedPercent() { return landSavedPercent; }
    public void setLandSavedPercent(Double landSavedPercent) { 
        this.landSavedPercent = landSavedPercent; 
    }
    
    public Long getWaterSavedLiters() { return waterSavedLiters; }
    public void setWaterSavedLiters(Long waterSavedLiters) { 
        this.waterSavedLiters = waterSavedLiters; 
    }
    
    public Long getCo2SavedKg() { return co2SavedKg; }
    public void setCo2SavedKg(Long co2SavedKg) { 
        this.co2SavedKg = co2SavedKg; 
    }
    
    public Long getLandSavedSqM() { return landSavedSqM; }
    public void setLandSavedSqM(Long landSavedSqM) { 
        this.landSavedSqM = landSavedSqM; 
    }
}
